{
  "name": "ticqex",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "predev:all": "tsx scripts/dev-preclean.ts && tsx --env-file=.env.local scripts/cancel-stuck-trigger-runs.ts",
    "dev:all": "concurrently --kill-others-on-fail -n next,trigger,watchdog -c blue,magenta,yellow \"pnpm dev\" \"pnpm trigger:dev\" \"pnpm trigger:watchdog\"",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:env": "tsx scripts/sync-supabase-env.ts",
    "env:sync": "pnpm db:env && tsx scripts/sync-cloud-env.ts && pnpm trigger:env",
    "env:verify": "tsx --env-file=.env.local scripts/verify-env.ts",
    "db:seed-admin": "tsx --env-file=.env.local scripts/seed.ts",
    "supabase": "supabase",
    "trigger:login": "trigger login",
    "trigger:init": "trigger init --skip-package-install",
    "trigger:create": "tsx scripts/create-trigger-project.ts",
    "trigger:env": "tsx scripts/sync-trigger-env.ts",
    "trigger:dev": "trigger dev --env-file .env.local --max-concurrent-runs 10",
    "trigger:clean": "rm -rf .trigger && tsx --env-file=.env.local scripts/cancel-stuck-trigger-runs.ts",
    "trigger:smoke": "tsx --env-file=.env.local scripts/trigger-smoke-test.ts",
    "trigger:watchdog": "tsx --env-file=.env.local scripts/trigger-stuck-watchdog.ts",
    "test:message-reads": "tsx --env-file=.env.local scripts/test-message-reads.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "@trigger.dev/sdk": "^4.4.6",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "supabase": "^2.100.1",
    "tailwindcss": "^4",
    "trigger.dev": "4.4.6",
    "tsx": "^4.22.3",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
