{
  "name": "ticqex",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source, agent-first support platform with first-class REST API and MCP, a realtime Kanban admin, and a composable channel layer (email parsing onboard). Built on Next.js and Supabase.",
  "license": "MIT",
  "homepage": "https://github.com/rbouschery/ticqex#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/rbouschery/ticqex.git"
  },
  "bugs": {
    "url": "https://github.com/rbouschery/ticqex/issues"
  },
  "keywords": [
    "agent-first",
    "ai-agents",
    "mcp",
    "support",
    "helpdesk",
    "ticketing",
    "kanban",
    "api",
    "nextjs",
    "supabase",
    "resend",
    "email"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:bootstrap": "tsx scripts/bootstrap-db.ts",
    "db:env": "tsx scripts/sync-supabase-env.ts",
    "env:verify": "tsx --env-file=.env.local scripts/verify-env.ts",
    "db:seed-admin": "tsx --env-file=.env.local scripts/seed.ts",
    "ticqex": "tsx scripts/ticqex.ts",
    "config:check": "tsx --env-file=.env.local scripts/config-check.ts",
    "config:sync": "tsx --env-file=.env.local scripts/config-sync.ts",
    "supabase": "supabase",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "seed:board-load": "tsx --env-file=.env.local scripts/seed-board-load.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@modelcontextprotocol/sdk": "1.26.0",
    "@phosphor-icons/react": "^2.1.10",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.2",
    "@tanstack/react-query": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.17.0",
    "mcp-handler": "^1.1.0",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "resend": "^6.12.4",
    "shadcn": "^4.10.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^25",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.7",
    "supabase": "^2.104.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  },
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8"
}
