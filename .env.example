# Supabase (local: `pnpm db:start` then `pnpm db:env`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

# Email — Resend (required for inbound/outbound)
RESEND_API_KEY=re_...
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
# Delivery events webhook signing secret (optional — falls back to RESEND_INBOUND_WEBHOOK_SECRET when using one webhook)
# RESEND_EVENTS_WEBHOOK_SECRET=whsec_...
# Resend events webhook URL: https://readbetter.rbouschery.de/api/webhooks/resend/events
# Events: email.sent, email.delivered, email.bounced, email.complained, email.failed
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support

# App URL (public tunnel hostname when using Cloudflare)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare named tunnel (Cursor Cloud harness only — not written to .env.local)
# CLOUDFLARE_TUNNEL_TOKEN=...
