# Supabase (local: `pnpm db:start` then `pnpm db:env`)
# Interactive setup: `pnpm ticqex init`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

# Email — Resend (required for inbound/outbound)
RESEND_API_KEY=re_...
# Created automatically by `pnpm ticqex init` or `pnpm resend:setup-webhooks`:
RESEND_WEBHOOK_SECRET=whsec_...
# Webhook targets (derived from NEXT_PUBLIC_APP_URL):
#   Resend: {NEXT_PUBLIC_APP_URL}/api/webhooks/integrations/resend
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support

# App URL (localhost for UI-only dev; HTTPS tunnel or deploy URL for inbound email)
NEXT_PUBLIC_APP_URL=http://localhost:3000
