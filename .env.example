# Supabase (local: `pnpm db:start` then `pnpm db:env`)
# Interactive setup: `pnpm ticqex init`
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Seed admin (scripts/seed.ts)
SEED_ADMIN_EMAIL=admin@ticqex.local
SEED_ADMIN_PASSWORD=ticqex-admin-change-me

# Email — Resend (required for inbound/outbound)
RESEND_API_KEY=re_...
RESEND_INBOUND_WEBHOOK_SECRET=whsec_...
# Delivery events webhook signing secret (optional — falls back to RESEND_INBOUND_WEBHOOK_SECRET when using one webhook)
# RESEND_EVENTS_WEBHOOK_SECRET=whsec_...
# Resend webhooks (Svix-signed; configure in Resend dashboard):
#   Inbound (email.received): {NEXT_PUBLIC_APP_URL}/api/webhooks/integrations/resend/inbound
#   Delivery events:          {NEXT_PUBLIC_APP_URL}/api/webhooks/integrations/resend/events
# Events: email.sent, email.delivered, email.bounced, email.complained, email.failed
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_FROM_NAME=Support

# App URL (public tunnel hostname when using Cloudflare)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cloudflare named tunnel (Cursor Cloud secrets — optional in .env.local for local dev)
# CLOUDFLARE_TUNNEL_TOKEN=...
